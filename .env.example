# Discord
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Continuum API
CONTINUUM_API_BASE_URL=https://api.continuumapp.co.za/api/v1
CONTINUUM_OAUTH_ISSUER_URL=https://api.continuumapp.co.za
# Optional — bot will register dynamically and store the result in bot_config if unset.
CONTINUUM_OAUTH_CLIENT_ID=
CONTINUUM_OAUTH_CLIENT_NAME=Continuum Discord Bot
CONTINUUM_OAUTH_REDIRECT_URI=https://continuum-discord-bot.up.railway.app/oauth/callback

# Bot service
BOT_PUBLIC_URL=https://continuum-discord-bot.up.railway.app
PORT=3000
# 32 bytes hex (64 chars). Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
# At least 32 chars. Generate with: openssl rand -base64 48
BOT_STATE_SIGNING_KEY=
DATABASE_URL=postgres://user:password@host:5432/dbname

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Optional
ALLOWED_GUILD_IDS=
LOG_LEVEL=info
NODE_ENV=production
